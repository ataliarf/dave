# Copy this file to .env and fill in real values where needed.
# `.env` is gitignored.

# --- Postgres -------------------------------------------------------------
POSTGRES_USER=dave
POSTGRES_PASSWORD=dave
POSTGRES_DB=dave
POSTGRES_PORT=5432
DATABASE_URL=postgres://dave:dave@localhost:5432/dave

# --- Neo4j ----------------------------------------------------------------
# Password must be at least 8 characters or Neo4j will refuse to start.
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4jneo4j
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_URI=bolt://localhost:7687

# --- Ingest ---------------------------------------------------------------
# Directory the backend reads artifacts from. Relative paths are resolved
# from the backend working directory; the default points at the repo's
# top-level `data/`.
INGEST_DATA_DIR=../data

# --- App ------------------------------------------------------------------
BACKEND_PORT=3000
FRONTEND_PORT=5173
LOG_LEVEL=info
NODE_ENV=development
